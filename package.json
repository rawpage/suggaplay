{
  "name": "suggaplay",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:website",
    "dev:website": "npm run dev -w @suggaplay/website",
    "dev:mobile": "npm run dev -w @suggaplay/mobile",
    "dev:mobile:go": "npm run dev:go -w @suggaplay/mobile",
    "dev:mobile:tunnel": "npm run dev:go:tunnel -w @suggaplay/mobile",
    "build": "npm run build:website",
    "build:website": "npm run build -w @suggaplay/website",
    "start": "npm run start -w @suggaplay/website",
    "lint": "npm run lint -w @suggaplay/website",
    "lint:fix": "npm run lint -w @suggaplay/website -- --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run typecheck -w @suggaplay/types && npm run typecheck -w @suggaplay/supabase && npm run typecheck -w @suggaplay/tokens && npm run typecheck -w @suggaplay/website",
    "typecheck:mobile": "npm run typecheck -w @suggaplay/mobile",
    "db:migrate": "node scripts/apply-migration.mjs",
    "vercel:env": "node scripts/setup-vercel-env.mjs --scope bukikoshoni"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "pg": "^8.22.0",
    "prettier": "^3.8.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^5"
  },
  "overrides": {
    "@suggaplay/website": {
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "@types/react": "^19.2.0",
      "@types/react-dom": "^19.2.0"
    },
    "@suggaplay/mobile": {
      "react": "19.1.0",
      "@types/react": "~19.1.10"
    }
  }
}
