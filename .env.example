# Public site URL (used for metadata and OG tags)
NEXT_PUBLIC_SITE_URL=https://www.suggaplay.com

# Supabase — Project Settings → API (https://supabase.com/dashboard)
# Project URL: Settings → Data API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Client key (browser + server) — use ONE of:
# • New: Publishable key (sb_publishable_...) from "Publishable and secret API keys" tab
# • Legacy: anon public key (eyJ...) from "Legacy anon, service_role API keys" tab
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only key — use ONE of:
# • New: Secret key (sb_secret_...) — click Reveal → Copy. NEVER commit or expose.
# • Legacy: service_role key (eyJ...) from Legacy tab
SUPABASE_SERVICE_ROLE_KEY=

# Database password — Settings → Database → Database password (for migrations only)
# Used by npm run db:migrate (or set full DATABASE_URL instead)
# SUPABASE_DB_PASSWORD=
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Optional: API endpoint for waitlist submissions (until Supabase table is wired)
# NEXT_PUBLIC_WAITLIST_API_URL=

# Stripe subscriptions (Step 15 — do not use credits/tokens)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_FOUNDING_PRICE_ID=
# STRIPE_STANDARD_PRICE_ID=

# Email (Step 4+)
# RESEND_API_KEY=
